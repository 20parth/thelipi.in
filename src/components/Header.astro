---
const links = [
  { href: '#features', label: 'Features' },
  { href: '#screenshots', label: 'Screenshots' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#contact', label: 'Contact' }
]
---

<header class="sticky top-0 z-50 w-full border-b border-border/60 bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-[1280px] items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.png" alt="LiPi logo" width="32" height="32" class="rounded-md" />
      <span class="text-lg font-bold text-brand">LiPi</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-sm font-medium text-foreground/70 transition-colors hover:text-brand">
          {l.label}
        </a>
      ))}
    </nav>

    <a
      href="#pricing"
      class="rounded-md bg-brand px-4 py-2 text-sm font-semibold text-white shadow-sm transition-opacity hover:opacity-90"
    >
      Get License
    </a>
  </div>
</header>
