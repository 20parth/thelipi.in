---
const DOWNLOAD_URL = 'https://thelipi.in/release/LiPi-Setup-1.0.0.exe'
---

<section id="download" class="bg-accent/30 py-20 px-4">
  <div class="mx-auto max-w-[1280px] text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Download LiPi</h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-muted-foreground">
      One installer, works fully offline once installed. Activate with a license key from the Pricing section below.
    </p>

    <a
      href={DOWNLOAD_URL}
      download
      onclick="window.clarity && window.clarity('event', 'download_exe')"
      class="mt-8 inline-flex h-14 items-center gap-2 rounded-full bg-brand px-10 text-base font-semibold text-white shadow-lg transition-opacity hover:opacity-90"
    >
      Download for Windows — v1.0.0
    </a>

    <p class="mt-4 text-sm text-muted-foreground">
      Currently available for Windows. A macOS version is planned and will ship here once ready.
    </p>
  </div>
</section>
