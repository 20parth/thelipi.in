---
const shots = [
  { src: '/screenshots/practice-mode.png', label: 'Practice Mode' },
  { src: '/screenshots/tutor-mode.png', label: 'Guided Lessons' },
  { src: '/screenshots/marathi-keyboard.png', label: 'Marathi Remington Keyboard' },
  { src: '/screenshots/results.png', label: 'Speed & Accuracy Report' }
]
---

<section id="screenshots" class="bg-accent/30 py-20 px-4">
  <div class="mx-auto max-w-[1280px]">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">See LiPi in action</h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Placeholder previews for now — real in-app screenshots are coming soon.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {shots.map((s) => (
        <figure class="overflow-hidden rounded-xl border border-border bg-white dark:bg-secondary shadow-sm">
          <img src={s.src} alt={`${s.label} — placeholder screenshot`} class="h-auto w-full" loading="lazy" />
          <figcaption class="border-t border-border px-4 py-3 text-sm font-medium text-foreground/80">
            {s.label}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
