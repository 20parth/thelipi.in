<footer id="contact" class="border-t border-border bg-accent/30 px-4 py-12">
  <div class="mx-auto flex max-w-[1280px] flex-col items-center gap-4 text-center">
    <div class="flex items-center gap-2">
      <img src="/logo.png" alt="LiPi logo" width="28" height="28" class="rounded-md" />
      <span class="text-base font-bold text-brand">LiPi</span>
    </div>

    <a
      href={DOWNLOAD_URL}
      download
      class="rounded-full bg-brand px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition-opacity hover:opacity-90"
    >
      Download for Windows
    </a>

    <p class="text-sm text-foreground/80">
      LiPi – The Typing Tutor · Designed &amp; Developed by Parth Bhawar
      <br />
      In Association with Creative Computers Academy | Rajesh Bhawar
    </p>

    <p class="text-sm text-muted-foreground">
      Support: Rajesh Bhawar ·
      <a href="mailto:creativerajesh1@gmail.com" class="text-brand">creativerajesh1@gmail.com</a>
      ·
      <a href="tel:+919422214653" class="text-brand">+91-9422214653</a>
    </p>

    <p class="text-xs text-muted-foreground">© {year} Parth Bhawar. All rights reserved.</p>
  </div>
</footer>
